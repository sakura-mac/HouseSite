{
  "name": "create-react-app",
  "version": "6.4.0",
  "private": true,
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.2.1",
    "@typescript-eslint/eslint-plugin": "^2.19.0",
    "babel-polyfill": "^6.26.0",
    "eslint": "^6.8.0",
    "eslint-config-react-app": "^5.2.0",
    "ev-emitter": "^1.1.1",
    "sass": "^1.69.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.27",
    "@fortawesome/free-brands-svg-icons": "^5.12.1",
    "@fortawesome/free-solid-svg-icons": "^5.12.1",
    "@fortawesome/react-fontawesome": "^0.1.8",
    "animate.css": "^4.1.0",
    "axios": "^0.21.1",
    "bootstrap": "^4.5.0",
    "concurrently": "^8.2.0",
    "desandro-matches-selector": "^2.0.2",
    "get-size": "^2.0.3",
    "google-map-react": "^1.1.6",
    "gray-matter": "^4.0.3",
    "isotope-layout": "^3.0.6",
    "outlayer": "^2.1.1",
    "prop-types": "^15.7.2",
    "react": "^16.13.0",
    "react-animated-css": "^1.2.1",
    "react-animations": "^1.0.0",
    "react-background-video-player": "^1.1.6",
    "react-bootstrap": "^1.0.1",
    "react-dom": "^16.13.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^5.3.0",
    "react-markdown": "^8.0.3",
    "react-modal-video": "^1.2.3",
    "react-router-dom": "^5.1.2",
    "react-scripts": "^3.4.0",
    "react-slick": "^0.25.2",
    "react-toastify": "^5.5.0",
    "react-wow": "^1.0.0",
    "slick-carousel": "^1.8.1",
    "styled-components": "^5.0.1"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
  "build:ci": "CI=false NODE_OPTIONS=--openssl-legacy-provider react-scripts build && npm run build:admin",
  "build": "NODE_OPTIONS=--openssl-legacy-provider react-scripts build && npm run build:admin",
  "build:admin": "cd admin && npm install && npm run build && cp -r dist ../build/admin",
    "test": "react-scripts test",
    "translate:ja": "node scripts/auto-translate.js ja",
    "add-house": "node scripts/add-house.js",
    "dev:admin": "cd admin && npm run dev",
    "dev:worker": "cd worker && npx wrangler dev",
    "dev": "concurrently \"npm run start\" \"npm run dev:worker\" \"npm run dev:admin\"",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app",
    "rules": {
      "no-unused-vars": "off",
      "jsx-a11y/accessible-emoji": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
